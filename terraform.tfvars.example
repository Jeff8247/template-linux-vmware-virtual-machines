# ─── vCenter Connection ───────────────────────────────────────────────────────
vsphere_server = "vcenter.corp.example.com"
vsphere_user   = "administrator@vsphere.local"
# vsphere_password = set via TF_VAR_vsphere_password

# ─── Infrastructure Placement ─────────────────────────────────────────────────
datacenter = "MYDC01"
cluster    = "MYCLU01"
datastore  = "MYDS01"
vm_folder  = "VMs/LinuxServers"

# ─── Template ─────────────────────────────────────────────────────────────────
template_name = "template-ubuntu-22.04-lts"

# ─── VM List ──────────────────────────────────────────────────────────────────
# Each entry can override any field from the module (CPU, memory, disks, tags, template, etc.).
# Omit any field to inherit the global default defined below in this file.
vms = {
  # 1. Comprehensive Linux Override: Every option customized
  "linux-app-01" = {
    datacenter    = "MYDC01"
    cluster       = "MYCLU01"
    resource_pool = "Resources/LinuxPool"
    vm_folder     = "VMs/Production/Linux"
    computer_name = "linux-app-01"
    annotation    = "High Performance Linux App Server"
    tags          = { "Environment" = "Prod", "OS" = "Ubuntu" }

    num_cpus             = 8
    num_cores_per_socket = 4
    memory               = 16384

    # Multi-bus Storage example
    scsi_controller_count = 2
    scsi_type             = "pvscsi"
    disks = [
      { label = "OS", size = 150, unit_number = 0 },
      { label = "Data", size = 200, unit_number = 16 } # Bus 1:0
    ]

    network_interfaces = [{ network_name = "VM Network" }]
    ip_settings        = [{ ipv4_address = "10.0.2.101", ipv4_netmask = 24 }]
    ipv4_gateway       = "10.0.2.1"

    # Linux Specific Guest OS settings
    time_zone = "Australia/Brisbane"

    # Optional: Additional server-specific setup script (Runs AFTER domain join)
    linux_script_text = <<-EOT
      apt-get install -y htop
    EOT
  }

  # 2. Likely Override Example: Just common specs
  "linux-app-02" = {
    num_cpus     = 4
    memory       = 8192
    disks        = [{ label = "OS", size = 150 }, { label = "Data", size = 50 }]
    ip_settings  = [{ ipv4_address = "10.0.2.102", ipv4_netmask = 24 }]
    ipv4_gateway = "10.0.2.1"
    time_zone    = "Australia/Brisbane"
  }

  # 3. Default Example: Takes every setting from the global defaults below
  "linux-app-03" = {}
}

# ─── Global Linux Defaults ────────────────────────────────────────────────────
num_cpus = 2
memory   = 4096

disks = [
  {
    label       = "disk0"
    size        = 150
    unit_number = 0
  },
  {
    label       = "disk1"
    size        = 50
    unit_number = 1
  }
]

network_interfaces = [
  { network_name = "NET01" }
]

dns_servers     = ["10.0.0.1", "10.0.0.2"]
dns_suffix_list = ["corp.example.com"]

domain    = "corp.example.com"
time_zone = "Australia/Brisbane"

# ─── Domain Join (Uses same TF_VARS as Windows) ─────────────────────────────
windows_domain         = "corp.example.com"
windows_domain_netbios = "CORP"
windows_domain_user    = "svc-domainjoin@corp.example.com"
# windows_domain_password = set via TF_VAR_windows_domain_password
windows_domain_ou = "OU=AppServers,OU=Servers,DC=corp,DC=example,DC=com"

# ─── Global Hardware Defaults ─────────────────────────────────────────────────
hardware_version     = 21
tools_upgrade_policy = "upgradeAtPowerCycle"
